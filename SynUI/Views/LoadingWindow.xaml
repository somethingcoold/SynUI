<Window x:Class="SynUI.Views.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Width="380" Height="200"
        ShowInTaskbar="True"
        Topmost="True"
        Loaded="Window_Loaded">

    <Window.Resources>
        <CubicEase x:Key="ease" EasingMode="EaseInOut" />

        <Storyboard x:Key="PulseGlow" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                             Storyboard.TargetProperty="Opacity"
                             From="0.25" To="0.7" Duration="0:0:1.4"
                             EasingFunction="{StaticResource ease}" />
        </Storyboard>

        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="RootPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5"
                             EasingFunction="{StaticResource ease}" />
            <DoubleAnimation Storyboard.TargetName="RootScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.88" To="1" Duration="0:0:0.6"
                             EasingFunction="{StaticResource ease}" />
            <DoubleAnimation Storyboard.TargetName="RootScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.88" To="1" Duration="0:0:0.6"
                             EasingFunction="{StaticResource ease}" />
        </Storyboard>
    </Window.Resources>

    <Border x:Name="RootPanel" CornerRadius="14" Opacity="0"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1" />
        </Border.RenderTransform>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0C0C0F" Offset="0" />
                <GradientStop Color="#131318" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.8" />
        </Border.Effect>

        <Grid>
            <!-- Accent glow behind brand -->
            <Ellipse Width="140" Height="140"
                     HorizontalAlignment="Center" VerticalAlignment="Top"
                     Margin="0,10,0,0" x:Name="GlowEffect" Opacity="0.4" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#307C5CFC" Offset="0" />
                        <GradientStop Color="#00000000" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-6,0,0">
                <!-- Brand text -->
                <TextBlock Text="SynUI"
                           FontSize="32" FontWeight="Bold"
                           Foreground="#E8E8ED"
                           HorizontalAlignment="Center"
                           FontFamily="Segoe UI">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#7C5CFC" BlurRadius="24" ShadowDepth="0" Opacity="0.35" />
                    </TextBlock.Effect>
                </TextBlock>

                <!-- Loading status text -->
                <TextBlock x:Name="LoadingStatusText" Text="Initializing..."
                           FontSize="11" Foreground="#55FFFFFF"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,18"
                           FontFamily="Segoe UI" />

                <!-- Progress bar container -->
                <Grid Width="220" Height="4" HorizontalAlignment="Center">
                    <!-- Track -->
                    <Border CornerRadius="2" Background="#15FFFFFF" />

                    <!-- Fill -->
                    <Border x:Name="ProgressFill" CornerRadius="2"
                            HorizontalAlignment="Left" Width="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#7C5CFC" Offset="0" />
                                <GradientStop Color="#5B8DEF" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#7C5CFC" BlurRadius="8" ShadowDepth="0" Opacity="0.5" />
                        </Border.Effect>
                    </Border>
                </Grid>

                <!-- Percentage -->
                <TextBlock x:Name="PercentageText" Text="0%"
                           FontSize="10" Foreground="#44FFFFFF"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"
                           FontFamily="Segoe UI" />
            </StackPanel>

            <!-- Border glow ring -->
            <Border CornerRadius="14" BorderThickness="1" IsHitTestVisible="False">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A7C5CFC" Offset="0" />
                        <GradientStop Color="#0AFFFFFF" Offset="0.5" />
                        <GradientStop Color="#1A5B8DEF" Offset="1" />
                    </LinearGradientBrush>
                </Border.BorderBrush>
            </Border>
        </Grid>
    </Border>
</Window>
