<Window x:Class="SynUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="SynUI"
        Width="1200" Height="740"
        MinWidth="860" MinHeight="540"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <CubicEase x:Key="Ease" EasingMode="EaseOut" />

        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="RootBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.45"
                             EasingFunction="{StaticResource Ease}" />
            <DoubleAnimation Storyboard.TargetName="MainScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.94" To="1" Duration="0:0:0.5"
                             EasingFunction="{StaticResource Ease}" />
            <DoubleAnimation Storyboard.TargetName="MainScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.94" To="1" Duration="0:0:0.5"
                             EasingFunction="{StaticResource Ease}" />
        </Storyboard>

        <!-- ─── Sidebar script tab button ─── -->
        <Style x:Key="ScriptBtn" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background"   Value="Transparent" />
            <Setter Property="Foreground"   Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"      Value="10,0,10,0" />
            <Setter Property="FontSize"     Value="12" />
            <Setter Property="FontFamily"   Value="JetBrains Mono, Cascadia Code, Consolas" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Height="30" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScriptBtnActive" TargetType="Button" BasedOn="{StaticResource ScriptBtn}">
            <Setter Property="Background" Value="{StaticResource BgActiveBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <!-- ─── Icon button (+ and toolbar) ─── -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background"   Value="Transparent" />
            <Setter Property="Foreground"   Value="{StaticResource TextMutedBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width"  Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="JetBrains Mono, Cascadia Code, Consolas" />
            <Setter Property="FontSize"   Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── Toolbar button (Hook / Clear) ─── -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background"   Value="{StaticResource BgSurfaceBrush}" />
            <Setter Property="Foreground"   Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush"  Value="{StaticResource BorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"      Value="10,4" />
            <Setter Property="FontSize"     Value="11" />
            <Setter Property="FontFamily"   Value="JetBrains Mono, Cascadia Code, Consolas" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgActiveBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── Execute button ─── -->
        <Style x:Key="ExecBtn" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background"   Value="{StaticResource AccentPurpleBrush}" />
            <Setter Property="Foreground"   Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"      Value="18,5" />
            <Setter Property="FontSize"     Value="11.5" />
            <Setter Property="FontWeight"   Value="SemiBold" />
            <Setter Property="FontFamily"   Value="JetBrains Mono, Cascadia Code, Consolas" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="{StaticResource AccentPurple}"
                                                  BlurRadius="10" ShadowDepth="0" Opacity="0.5" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentPurpleHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.97" ScaleY="0.97" /></Setter.Value>
                                </Setter>
                                <Setter TargetName="Bd" Property="RenderTransformOrigin" Value="0.5,0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── Tab close button ─── -->
        <Style x:Key="CloseTabBtn" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Width"  Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Background"   Value="Transparent" />
            <Setter Property="Foreground"   Value="{StaticResource TextMutedBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Visibility" Value="Hidden" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                            <TextBlock Text="✕" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1FEF4444" />
                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── TitleBar window control buttons ─── -->
        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Width"  Value="42" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background"   Value="Transparent" />
            <Setter Property="Foreground"   Value="{StaticResource TextMutedBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseTitleBtn" TargetType="Button" BasedOn="{StaticResource TitleBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="0,10,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentRedBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── Dark ComboBox ─── -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background"   Value="{StaticResource BgSurfaceBrush}" />
            <Setter Property="Foreground"   Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush"  Value="{StaticResource BorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily"   Value="JetBrains Mono, Cascadia Code, Consolas" />
            <Setter Property="FontSize"     Value="11" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="Padding"      Value="8,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                                <TextBlock Grid.Column="1" Text="▾" FontSize="9"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True" Focusable="False"
                                       PopupAnimation="Fade" Placement="Bottom">
                                    <Border Background="{DynamicResource BgElevatedBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="4"
                                            MaxHeight="200" MinWidth="{TemplateBinding ActualWidth}">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000" BlurRadius="16" ShadowDepth="4" Opacity="0.5" />
                                        </Border.Effect>
                                        <ScrollViewer>
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentPurpleBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="OverridesDefaultStyle" Value="True" />
                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                        <Setter Property="FontFamily" Value="JetBrains Mono, Cascadia Code, Consolas" />
                        <Setter Property="FontSize"   Value="11" />
                        <Setter Property="Cursor"     Value="Hand" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="3"
                                            Padding="10,6" Margin="3,1">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ══════════════════ ROOT BORDER (shadow + fade-in) ══════════════════ -->
    <Border x:Name="RootBorder" CornerRadius="10" Opacity="0"
            Background="{DynamicResource BgDeepBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="MainScale" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="4" Opacity="0.7" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />   <!-- Title bar -->
                <RowDefinition Height="*"  />   <!-- Content   -->
                <RowDefinition Height="30" />   <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ══════════ TITLE BAR ══════════ -->
            <Border Grid.Row="0" Background="{DynamicResource BgBaseBrush}"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <!-- Branding -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="◈" FontSize="14" Foreground="{DynamicResource AccentPurpleBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="{StaticResource AccentPurple}"
                                                  BlurRadius="10" ShadowDepth="0" Opacity="0.7" />
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="SYNUI" FontSize="12" FontWeight="Bold"
                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="VersionLabel" Text="  v1.0"
                                   FontSize="10" FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="⚙" Style="{StaticResource TitleBtn}" Click="Settings_Click"
                                ToolTip="Settings"
                                FontFamily="Segoe UI" FontSize="13" />
                        <Button Content="&#xE949;" Style="{StaticResource TitleBtn}" Click="Minimize_Click" />
                        <Button x:Name="MaximizeBtn" Content="&#xE739;" Style="{StaticResource TitleBtn}" Click="Maximize_Click" />
                        <Button Content="&#xE106;" Style="{StaticResource CloseTitleBtn}" Click="Close_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════ MAIN CONTENT ══════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210" />   <!-- Sidebar -->
                    <ColumnDefinition Width="1"   />   <!-- Divider -->
                    <ColumnDefinition Width="*"   />   <!-- Editor + Terminal -->
                </Grid.ColumnDefinitions>

                <!-- ── SIDEBAR ── -->
                <Border Grid.Column="0" Background="{DynamicResource BgBaseBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />   <!-- Scripts header -->
                            <RowDefinition Height="*"   />   <!-- Scroll area -->
                        </Grid.RowDefinitions>

                        <!-- Scripts header -->
                        <Border Grid.Row="0" Padding="12,13,10,8"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <TextBlock Text="SCRIPTS"
                                           FontSize="9.5" FontWeight="Bold"
                                           FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center" />
                                <Button Style="{StaticResource IconBtn}" Content="+"
                                        HorizontalAlignment="Right"
                                        Click="AddTab_Click" ToolTip="New Script" />
                            </Grid>
                        </Border>

                        <!-- Scrollable tab list -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="0,6,0,0">
                                <!-- Regular scripts -->
                                <StackPanel x:Name="TabList" Margin="6,0" />

                                <!-- Auto Exec header -->
                                <Border Padding="12,16,10,8" Margin="0,6,0,0"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
                                    <Grid>
                                        <TextBlock Text="AUTO EXEC"
                                                   FontSize="9.5" FontWeight="Bold"
                                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                                   Foreground="#FF3B82F6"
                                                   VerticalAlignment="Center" />
                                        <Button Style="{StaticResource IconBtn}" Content="+"
                                                HorizontalAlignment="Right"
                                                Click="AddAutoExecTab_Click" ToolTip="New Auto Exec Script" />
                                    </Grid>
                                </Border>

                                <!-- Auto exec scripts -->
                                <StackPanel x:Name="AutoExecTabList" Margin="6,0,6,8" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Sidebar divider -->
                <Border Grid.Column="1" Background="{DynamicResource BorderSubtleBrush}" />

                <!-- ── EDITOR + TERMINAL ── -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"   />   <!-- Editor  -->
                        <RowDefinition Height="5"   />   <!-- Splitter -->
                        <RowDefinition Height="220" MinHeight="80" />  <!-- Terminal (toolbar + body) -->
                    </Grid.RowDefinitions>

                    <!-- Editor -->
                    <Border Grid.Row="0" Background="{DynamicResource BgSurfaceBrush}">
                        <avalonEdit:TextEditor x:Name="CodeEditor"
                                               FontFamily="JetBrains Mono, Cascadia Code, Fira Code, Consolas"
                                               FontSize="13"
                                               ShowLineNumbers="True"
                                               WordWrap="False"
                                               Background="{DynamicResource BgSurfaceBrush}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               LineNumbersForeground="{DynamicResource TextMutedBrush}"
                                               Padding="14,12"
                                               HorizontalScrollBarVisibility="Auto"
                                               VerticalScrollBarVisibility="Auto"
                                               TextChanged="CodeEditor_TextChanged" />
                    </Border>

                    <!-- Grid Splitter (resizes Editor ↔ Terminal) -->
                    <GridSplitter Grid.Row="1"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="{DynamicResource BorderSubtleBrush}"
                                  Cursor="SizeNS"
                                  ResizeDirection="Rows"
                                  ShowsPreview="False"
                                  ResizeBehavior="PreviousAndNext" />

                    <!-- Welcome Overlay (shown when no scripts exist) -->
                    <Grid x:Name="WelcomeOverlay" Grid.Row="0" Grid.RowSpan="3"
                          Visibility="Visible"
                          Background="{DynamicResource BgSurfaceBrush}"
                          Panel.ZIndex="10">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    MaxWidth="360">
                            <!-- Logo -->
                            <TextBlock Text="◈" FontSize="48"
                                       FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                       Foreground="{DynamicResource AccentPurpleBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,12">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="{StaticResource AccentPurple}"
                                                      BlurRadius="24" ShadowDepth="0" Opacity="0.6" />
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="SYNUI"
                                       FontSize="28" FontWeight="Bold"
                                       FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,6" />
                            <TextBlock Text="Multiple scripts · Console logging · Auto-exec support"
                                       FontSize="11"
                                       FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,32" />

                            <!-- Action buttons -->
                            <Button Content="+ New Script" Style="{StaticResource ExecBtn}"
                                    HorizontalAlignment="Center" Width="200" Margin="0,0,0,10"
                                    Click="WelcomeNewScript_Click" />
                            <Button Content="+ New Auto Exec" Style="{StaticResource ToolBtn}"
                                    HorizontalAlignment="Center" Width="200" Margin="0,0,0,10"
                                    Click="WelcomeNewAutoExec_Click" />
                            <Button Content="⚙ Settings" Style="{StaticResource ToolBtn}"
                                    HorizontalAlignment="Center" Width="200"
                                    Click="Settings_Click" />

                            <!-- Feature list -->
                            <Border Background="{DynamicResource BgBaseBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="20,14" Margin="0,32,0,0">
                                <StackPanel>
                                    <TextBlock Text="• Auto-complete Luau script editor"
                                               FontSize="11.5"
                                               FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,0,0,6" />
                                    <TextBlock Text="• Console logging &amp; output capture"
                                               FontSize="11.5"
                                               FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,0,0,6" />
                                    <TextBlock Text="• Multi-instance &amp; PID targeting"
                                               FontSize="11.5"
                                               FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,0,0,6" />
                                    <TextBlock Text="• Auto-exec script support"
                                               FontSize="11.5"
                                               FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                </StackPanel>
                            </Border>

                            <Button x:Name="ContinueBtn" Content="Continue to Editor →"
                                    Style="{StaticResource ToolBtn}"
                                    HorizontalAlignment="Center" Width="200" Margin="0,12,0,0"
                                    Visibility="Collapsed"
                                    Click="ContinueToEditor_Click" />
                        </StackPanel>
                    </Grid>

                    <!-- Terminal Panel (toolbar + body) -->
                    <DockPanel Grid.Row="2" Background="#050507">
                        <!-- Toolbar -->
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource BgBaseBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="0,1,0,1">
                            <Grid Height="36" Margin="10,0">
                                <!-- Left: label + controls -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="CONSOLE"
                                               FontSize="9.5" FontWeight="Bold"
                                               FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               VerticalAlignment="Center" />

                                    <Border Width="1" Height="14" Background="{DynamicResource BorderSubtleBrush}" />

                                    <ComboBox x:Name="InstanceSelector"
                                              Style="{StaticResource DarkCombo}"
                                              Width="140" Margin="6,0,0,0"
                                              SelectionChanged="InstanceSelector_Changed" />

                                    <Button Content="Hook Console" Style="{StaticResource ToolBtn}"
                                            Margin="6,0,0,0"
                                            Click="HookConsole_Click" ToolTip="Inject LogService hook into Roblox" />

                                    <Button Content="Clear" Style="{StaticResource ToolBtn}"
                                            Margin="6,0,0,0"
                                            Click="ClearTerminal_Click" ToolTip="Clear console output" />
                                </StackPanel>

                                <!-- Right: Execute -->
                                <Button Content="▶  Execute" Style="{StaticResource ExecBtn}"
                                        HorizontalAlignment="Right"
                                        Click="Execute_Click" ToolTip="Execute (Ctrl+Enter)" />
                            </Grid>
                        </Border>

                        <!-- Terminal body (fills remaining DockPanel space) -->
                        <RichTextBox x:Name="TerminalBox"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                     FontSize="12"
                                     BorderThickness="0"
                                     Padding="10,6"
                                     IsReadOnly="True"
                                     IsDocumentEnabled="False"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Focusable="False" />
                    </DockPanel>
                </Grid>
            </Grid>

            <!-- ══════════ STATUS BAR ══════════ -->
            <Border Grid.Row="2" Background="{DynamicResource BgBaseBrush}"
                    CornerRadius="0,0,10,10"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0,1,0,0">
                <Grid Margin="12,0">
                    <!-- Left: WEAO + Roblox version + exec status -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="WeaoStatusDot" Width="6" Height="6"
                                 Fill="{DynamicResource TextMutedBrush}" Margin="0,0,5,0" />
                        <TextBlock x:Name="WeaoStatusText" Text="Checking…"
                                   FontSize="10.5"
                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center" />

                        <TextBlock Text="  ·  " Foreground="{DynamicResource BorderBrush}"
                                   FontSize="10" VerticalAlignment="Center" />

                        <TextBlock x:Name="RobloxVersionText" Text=""
                                   FontSize="10.5"
                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center" />

                        <TextBlock x:Name="ExecSeparator" Text="  ·  " Foreground="{DynamicResource BorderBrush}"
                                   FontSize="10" VerticalAlignment="Center" Visibility="Collapsed" />

                        <Ellipse x:Name="StatusDot" Width="5" Height="5"
                                 Fill="{DynamicResource TextMutedBrush}" Margin="0,0,5,0"
                                 Visibility="Collapsed" />

                        <TextBlock x:Name="StatusText" Text=""
                                   FontSize="10.5"
                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Right: script count + shortcut hint -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="ScriptCountText" Text="0 scripts"
                                   FontSize="10.5"
                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="  ·  " Foreground="{DynamicResource BorderBrush}"
                                   FontSize="10" VerticalAlignment="Center" />
                        <Border BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                                CornerRadius="2" Padding="4,1">
                            <TextBlock Text="Ctrl+Enter"
                                       FontSize="9.5"
                                       FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
