<Window x:Class="SynUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="SynUI"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">

    <Window.Resources>
        <CubicEase x:Key="ease" EasingMode="EaseOut" />

        <Storyboard x:Key="WindowFadeIn">
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5"
                             EasingFunction="{StaticResource ease}" />
            <DoubleAnimation Storyboard.TargetName="MainScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.92" To="1" Duration="0:0:0.6"
                             EasingFunction="{StaticResource ease}" />
            <DoubleAnimation Storyboard.TargetName="MainScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.92" To="1" Duration="0:0:0.6"
                             EasingFunction="{StaticResource ease}" />
        </Storyboard>

        <!-- Tab item button style -->
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                Margin="4,1">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active tab style -->
        <Style x:Key="TabButtonActive" TargetType="Button" BasedOn="{StaticResource TabButton}">
            <Setter Property="Background" Value="{StaticResource BgActiveBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <!-- Title bar button -->
        <Style x:Key="TitleBarBtn" TargetType="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button -->
        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource TitleBarBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentRedBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Execute button -->
        <Style x:Key="ExecuteBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentPurpleBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="22,8" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="{StaticResource AccentPurple}"
                                                  BlurRadius="16" ShadowDepth="0" Opacity="0.35" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource AccentPurpleHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Bd" Property="RenderTransformOrigin" Value="0.5,0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Add tab button -->
        <Style x:Key="AddTabBtn" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Width="28" Height="28">
                            <TextBlock Text="+" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}" Margin="0,-2,0,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentPurpleBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small icon button (for tab close) -->
        <Style x:Key="TabCloseBtn" TargetType="Button">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Visibility" Value="Hidden" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Width="18" Height="18">
                            <TextBlock Text="✕" FontSize="9"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33EF4444" />
                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="MainBorder" CornerRadius="12" Opacity="0"
            Background="{StaticResource BgDeepBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="MainScale" ScaleX="1" ScaleY="1" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="2" Opacity="0.6" />
        </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="46" />  <!-- Title bar -->
                    <RowDefinition Height="*" />   <!-- Content -->
                    <RowDefinition Height="52" />  <!-- Bottom bar -->
                </Grid.RowDefinitions>

                <!-- ═══ TITLE BAR ═══ -->
                <Border Grid.Row="0" Background="{StaticResource BgBaseBrush}"
                        CornerRadius="12,12,0,0"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                        MouseLeftButtonUp="TitleBar_MouseLeftButtonUp">
                <Grid>
                    <!-- App branding -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="◆" Foreground="{StaticResource AccentPurpleBrush}"
                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,7,0" />
                        <TextBlock Text="SynUI" FontSize="12.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" FontFamily="Segoe UI" />
                        <TextBlock Text="v1.0" FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center" Margin="6,1,0,0" />
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="&#xE949;" Style="{StaticResource TitleBarBtn}"
                                Click="Minimize_Click" ToolTip="Minimize" />
                        <Button x:Name="MaximizeBtn" Content="&#xE739;" Style="{StaticResource TitleBarBtn}"
                                Click="Maximize_Click" ToolTip="Maximize" />
                        <Button Content="&#xE106;" Style="{StaticResource CloseBtn}"
                                Click="Close_Click" ToolTip="Close" />
                    </StackPanel>
                </Grid>
            </Border>

                <!-- ═══ MAIN CONTENT ═══ -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />  <!-- Sidebar -->
                        <ColumnDefinition Width="1" />    <!-- Divider -->
                        <ColumnDefinition Width="*" />    <!-- Editor -->
                    </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0" Background="{StaticResource BgBaseBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                            <!-- Sidebar header -->
                            <Border Grid.Row="0" Padding="18,16,14,12">
                                <Grid>
                                    <TextBlock Text="S C R I P T S"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe UI" />
                                    <Button Style="{StaticResource AddTabBtn}"
                                            HorizontalAlignment="Right"
                                            Click="AddTab_Click" ToolTip="New Script" />
                                </Grid>
                            </Border>

                        <!-- Tab lists -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,0,0,0">
                            <StackPanel>
                                <!-- Regular Scripts -->
                                <StackPanel x:Name="TabList" />

                                <!-- Auto Exec Header -->
                                <Border Padding="18,24,14,12">
                                    <Grid>
                                        <TextBlock Text="A U T O   E X E C"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Segoe UI" />
                                        <Button Style="{StaticResource AddTabBtn}"
                                                HorizontalAlignment="Right"
                                                Click="AddAutoExecTab_Click" ToolTip="New Auto Exec Script" />
                                    </Grid>
                                </Border>
                                
                                <!-- Auto Exec Scripts -->
                                <StackPanel x:Name="AutoExecTabList" />
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Sidebar footer -->
                        <Border Grid.Row="2" Padding="10,6,10,10"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="0,1,0,0">
                            <TextBlock x:Name="ScriptCountText" Text="0 scripts"
                                       FontSize="10.5" Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="Segoe UI" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Divider -->
                <Border Grid.Column="1" Background="{StaticResource BorderSubtleBrush}" />

                <!-- EDITOR -->
                <Border Grid.Column="2" Background="{StaticResource BgSurfaceBrush}">
                    <avalonEdit:TextEditor x:Name="CodeEditor"
                                           FontFamily="JetBrains Mono, Cascadia Code, Fira Code, Consolas"
                                           FontSize="13"
                                           ShowLineNumbers="True"
                                           WordWrap="False"
                                               Background="{StaticResource BgSurfaceBrush}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               LineNumbersForeground="{StaticResource TextMutedBrush}"
                                               Padding="16,14"
                                           HorizontalScrollBarVisibility="Auto"
                                           VerticalScrollBarVisibility="Auto"
                                           TextChanged="CodeEditor_TextChanged" />
                </Border>
            </Grid>

            <!-- ═══ BOTTOM BAR ═══ -->
            <Border Grid.Row="2" Background="{StaticResource BgBaseBrush}"
                    CornerRadius="0,0,12,12"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,1,0,0">
                <Grid Margin="14,0">
                    <!-- Left: WEAO Status + Exec Status -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <!-- WEAO status dot (animated) -->
                        <Ellipse x:Name="WeaoStatusDot" Width="7" Height="7"
                                 Fill="{StaticResource TextMutedBrush}" Margin="0,0,6,0" />
                        <TextBlock x:Name="WeaoStatusText" Text="Checking..."
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center" FontFamily="Segoe UI" />

                        <!-- Separator -->
                        <TextBlock Text="│" Foreground="{StaticResource BorderBrush}"
                                   FontSize="11" Margin="10,0" VerticalAlignment="Center" />

                        <!-- Roblox version -->
                        <TextBlock x:Name="RobloxVersionText" Text=""
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center" FontFamily="Segoe UI" />



                        <!-- Separator (only visible when exec status is showing) -->
                        <TextBlock x:Name="ExecSeparator" Text="│" Foreground="{StaticResource BorderBrush}"
                                   FontSize="11" Margin="10,0" VerticalAlignment="Center" 
                                   Visibility="Collapsed" />

                        <!-- Execution status -->
                        <Ellipse x:Name="StatusDot" Width="6" Height="6"
                                 Fill="{StaticResource TextMutedBrush}" Margin="0,0,6,0" 
                                 Visibility="Collapsed" />
                        <TextBlock x:Name="StatusText" Text=""
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" FontFamily="Segoe UI" />
                    </StackPanel>

                    <!-- Right: Execute button -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Execute" Style="{StaticResource ExecuteBtn}"
                                    Click="Execute_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
